# Sunucu
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/medora

# JWT
JWT_SECRET=cok-gizli-anahtar-degistir
JWT_EXPIRES_IN=7d

# OTP ayarları
OTP_LENGTH=6
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ----------------- BİLDİRİM (OTP gönderim kanalı) -----------------
# Hangi kanal kullanılacak: mock | whatsapp | email
# - mock     : OTP terminale yazılır. Geliştirme/demo için ücretsiz.
# - whatsapp : Meta WhatsApp Cloud API. Ayda 1000 mesaj ücretsiz.
# - email    : SMTP ile e-postaya gönderir (Gmail vb. ile %100 ücretsiz).
MESSAGE_PROVIDER=mock

# WhatsApp Cloud API (MESSAGE_PROVIDER=whatsapp ise)
# https://developers.facebook.com -> WhatsApp -> Get Started
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_TEMPLATE_NAME=medora_otp
WHATSAPP_TEMPLATE_LANG=tr

# SMTP / E-posta (MESSAGE_PROVIDER=email ise)
# Gmail için: 2FA aç -> "Uygulama şifresi" oluştur -> SMTP_PASS olarak kullan
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Dosya yükleme
MAX_UPLOAD_MB=10

# Admin (klinik onayı için ilk admin kullanıcısı)
SEED_ADMIN_EMAIL=admin@medora.local
SEED_ADMIN_PASSWORD=Admin123!
